<html>

<head>
    <style>
        @media (prefers-color-scheme: dark) {
            body {
                background: #333;
                color: white;
            }
            a {
                color: skyblue;
            }
        }
        .container {
            font-family: sans-serif;
            max-width: 800px;
            margin: 0 auto;
        }
        .intro {
            text-align: center;
        }
        .licenses-list {
            list-style-type: none;
            margin: 0;
            padding: 0;
        }
        .license-used-by {
            margin-top: -10px;
        }
        .license-text {
            max-height: 200px;
            overflow-y: scroll;
            white-space: pre-wrap;
        }
    </style>
</head>

<body>
    <main class="container">
        <div class="intro">
            <h1>Space Shooter — Third Party Licenses</h1>
            <p>This page lists the licenses of all dependencies and assets used in this project.</p>
        </div>

        <h2>Non-Code Assets</h2>
        <ul>
            <li>
                <strong>Space Shooter Starter Pack</strong> by
                <a href="https://anim86.itch.io">anim86</a>
                — <a href="https://anim86.itch.io/space-shoter-starter-pack">itch.io</a>
                <br>Free asset pack, used with credit to the author.
            </li>
            <li>
                <strong>Fira Mono</strong> by Mozilla Corporation &amp; Telefonica S.A.
                — <a href="https://fonts.google.com/specimen/Fira+Mono">Google Fonts</a>
                <br>Licensed under the
                <a href="https://openfontlicense.org">SIL Open Font License 1.1</a>
            </li>
        </ul>

        <h2>Overview of licenses:</h2>
        <ul class="licenses-overview">
            {{#each overview}}
            <li><a href="#{{id}}">{{name}}</a> ({{count}})</li>
            {{/each}}
        </ul>

        <h2>All license text:</h2>
        <ul class="licenses-list">
            {{#each licenses}}
            <li class="license">
                <h3 id="{{id}}">{{name}}</h3>
                <h4>Used by:</h4>
                <ul class="license-used-by">
                    {{#each used_by}}
                    <li><a href="{{#if crate.repository}} {{crate.repository}} {{else}} https://crates.io/crates/{{crate.name}} {{/if}}">{{crate.name}} {{crate.version}}</a></li>
                    {{/each}}
                </ul>
                <pre class="license-text">{{text}}</pre>
            </li>
            {{/each}}
        </ul>
    </main>
</body>

</html>